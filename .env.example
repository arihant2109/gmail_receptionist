# Copy to .env and fill in. Never commit .env.

# LLM (required for intent + reply)
# Get a free key: Groq https://console.groq.com or OpenAI https://platform.openai.com
LLM_API_KEY=
LLM_PROVIDER=groq

# Groq model (if LLM_PROVIDER=groq)
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI model (if LLM_PROVIDER=openai)
# OPENAI_MODEL=gpt-3.5-turbo

# Email (required to send issue/booking emails)
# Resend: https://resend.com – 3k emails/month free
RESEND_API_KEY=

# Optional: From address (Resend requires a verified domain for production)
# EMAIL_FROM=receptionist@yourdomain.com

# Optional: Next.js dev/prod port (default 3000)
# PORT=3000
